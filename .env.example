# JARVIS environment variables — copy to .env.local for local dev, and set the
# real values in the Vercel project settings (Settings → Environment Variables).
# DO NOT commit real secrets. This file documents names + placeholder values only.

# ── Autonomous SEO action engine ────────────────────────────────────────────
# GitHub token used to read/commit files in the TPS site + JARVIS repos.
# Use a fine-grained PAT scoped to ONLY these two repos with Contents: read/write.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Repos the engine writes to (defaults shown — override only if they move).
GITHUB_REPO=totalpropertysolutionspro-del/tpspro-website
JARVIS_REPO=totalpropertysolutionspro-del/jarvis-app

# Shared secret that gates every write endpoint (update-meta, publish-blog,
# gbp-post, seo-actions?apply=true). Generate a long random string.
# Requests must send it as the `x-jarvis-token` header. If unset, writes are refused.
JARVIS_ACTION_TOKEN=generate-a-long-random-string

# ── Google Business Profile (local posts) ───────────────────────────────────
GMB_OAUTH_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GMB_OAUTH_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx
GMB_OAUTH_REFRESH_TOKEN=1//xxxxxxxxxxxxxxxxxxxxxxxx
# Numeric IDs of the TPS Pro account + location (from the Business Profile API).
GBP_ACCOUNT_ID=000000000000000000000
GBP_LOCATION_ID=00000000000000000000

# ── Google Search Console (existing — used by /api/gsc-data, /api/seo-audit) ──
# Preferred: service-account JSON (granted access in Search Console).
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Fallback: OAuth2 user credentials.
GOOGLE_OAUTH_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx
GOOGLE_OAUTH_REFRESH_TOKEN=1//xxxxxxxxxxxxxxxxxxxxxxxx

# ── JARVIS Chat (existing — /api/jarvis-chat) ───────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
